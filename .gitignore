# --- Python関連 (venv, pyenv) ---
# 仮想環境ディレクトリ (よく使われる名前)
.venv/
venv/
env/
ENV/

# pyenvのローカルバージョン指定ファイル
# (チームでPythonバージョンを共有するため、除外せずにコミットすることを推奨します)
#!.python-version

# --- キャッシュ・コンパイル済みファイル ---
__pycache__/
*.py[cod]
*$py.class

# --- IDE・エディタ設定 ---
# VS Code
.vscode/
.history/

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# --- パッケージ・ビルド関連 ---
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- ログ・データベース ---
*.log
*.sqlite
*.sqlite3

# --- OS固有ファイル ---
.DS_Store
Thumbs.db

# --- LLMモデル・巨大なデータ ---
# modelsフォルダ自体は残し、中身のファイルだけを除外する
models/*
# ただし、.gitkeepファイルだけは除外しない（Gitに含める）
!models/.gitkeep

# --- 保存データ ---
# 保存データフォルダ全体を除外する
data/*
# ただし、.gitkeepファイルだけは除外しない（Gitに含める）
!data/.gitkeep

# --- envファイル ---
.env
