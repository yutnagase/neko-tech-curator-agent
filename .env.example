# ==================== 必須設定 ====================
# 必ずこのファイルを .env にコピーして使用してください

# LLMモデルパス（必ず存在するGGUFファイルを指定）
LLM_MODEL_PATH=models/llama3.2-3b-q4_k_m.gguf

# ==================== オプション ====================
LLM_N_CTX=8192
LLM_N_GPU_LAYERS=0
LLM_N_THREADS=8

# データベース
DB_PATH=data/explanations.db
VECTOR_DB_PATH=data/vector_db

# デバッグ
DEBUG=true